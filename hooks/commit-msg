#!/usr/bin/env bash
# Reject commits that expose Cursor, AI models, or non-owner attribution.

set -euo pipefail

MSG_FILE="${1:?commit message file required}"

FORBIDDEN_MSG_PATTERNS=(
  '(?i)co-authored-by:.*(cursor|composer|claude|gpt|copilot|openai|anthropic|agent|llm)'
  '(?i)(assisted-by|signed-off-by):.*(cursor|composer|claude|gpt|copilot|openai|anthropic|agent|llm)'
  '(?i)\b(cursor|composer|copilot)\b'
  '(?i)\b(generated by|written by|created by).*(claude|gpt|cursor|composer|copilot|llm|ai)\b'
  '(?i)\b(claude|gpt-?[0-9]|openai|anthropic)\b'
  '(?i)大模型|AI生成|AI 生成'
)

FORBIDDEN_IDENT_PATTERNS=(
  '(?i)cursor'
  '(?i)composer'
  '(?i)copilot'
  '(?i)claude'
  '(?i)\bgpt\b'
  '(?i)openai'
  '(?i)anthropic'
  '(?i)noreply@cursor'
  '(?i)@cursor\.com'
)

fail() {
  echo "commit-msg hook: $1" >&2
  echo "提示: 提交不得包含 Cursor、AI 模型或其他非本人身份信息。" >&2
  exit 1
}

message="$(cat "$MSG_FILE")"

if [[ -z "${message//[[:space:]]/}" ]]; then
  fail "提交说明不能为空。"
fi

for pattern in "${FORBIDDEN_MSG_PATTERNS[@]}"; do
  if printf '%s' "$message" | grep -Eiq "$pattern"; then
    fail "提交说明含有禁止的 AI/Cursor 相关信息。"
  fi
done

for ident_var in GIT_AUTHOR_IDENT GIT_COMMITTER_IDENT; do
  ident="$(git var "$ident_var" 2>/dev/null || true)"
  [[ -z "$ident" ]] && continue
  for pattern in "${FORBIDDEN_IDENT_PATTERNS[@]}"; do
    if printf '%s' "$ident" | grep -Eiq "$pattern"; then
      fail "提交者/提交人身份 ($ident_var) 含有禁止的 AI/Cursor 相关信息: $ident"
    fi
  done
done

exit 0
